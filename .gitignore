# ─── Dependencies ───────────────────────────────────────────────────────────
node_modules/

# ─── Build Outputs ──────────────────────────────────────────────────────────
dist/
out/
release/

# ─── Electron Builder Staging ────────────────────────────────────────────────
# Keep build/ folder (contains app icons: icon.ico, icon.icns, icon.png)
# but ignore any packaged outputs inside it
build/*.exe
build/*.zip
build/*.AppImage
build/*.deb
build/*.dmg

# ─── Environment Variables ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
# Keep .env.example (safe template for new contributors)
!.env.example

# ─── Logs ───────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Cache / Vite ───────────────────────────────────────────────────────────
.vite/
.cache/
*.eslintcache
*.tsbuildinfo

# ─── Generated PDFs ─────────────────────────────────────────────────────────
*.pdf

# ─── OS Files ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── IDE / Editor Configs ───────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ─── Runtime / Temp Scripts ─────────────────────────────────────────────────
*.tmp
*.bak
scratch/
test-*.mjs
debug-*.js

# ─── AI Assistant Configs ───────────────────────────────────────────────────
GEMINI.md
.gemini/
